<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaozhi.authrolepermission.dal.mysql.mapper.AuthRolePermissionMapper">

    <insert id="insertBatch">
        INSERT INTO sys_auth_role_permission (authRoleId, permissionId) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.authRoleId}, #{item.permissionId})
        </foreach>
    </insert>

</mapper>
